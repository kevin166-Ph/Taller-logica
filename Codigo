# 8. Carrito de compras
# ===============================
def agregar_producto(carrito, nombre, precio, cantidad):
    carrito[nombre] = {"precio": precio, "cantidad": cantidad}

def total_pagar(carrito):
    total = 0
    for p in carrito.values():
        total += p["precio"] * p["cantidad"]
    return total

def aplicar_descuento(total, descuento):
    return total * (1 - descuento)

carrito = {}
agregar_producto(carrito, "camisa", 20000, 2)
total = total_pagar(carrito)
print("8:", aplicar_descuento(total, 0.1))


