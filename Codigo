# 2. Aprobados
# ===============================
def aprobados(estudiantes):
    lista_aprobados = []
    for nombre, nota in estudiantes:
        if nota >= 3.0:
            lista_aprobados.append(nombre)
    return lista_aprobados

estudiantes = [("Ana", 3.5), ("Luis", 2.9), ("Carlos", 4.2)]
print("2:", aprobados(estudiantes))


