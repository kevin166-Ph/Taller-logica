# 7. Convertir notas
# ===============================
def convertir_nota(nota):
    rangos = (
        (4.5, "A"),
        (4.0, "B"),
        (3.0, "C"),
        (2.0, "D"),
        (0, "F")
    )
    
    for limite, letra in rangos:
        if nota >= limite:
            return letra

def reporte(estudiantes):
    resultado = {}
    for nombre, nota in estudiantes:
        resultado[nombre] = convertir_nota(nota)
    return resultado

datos = [("Ana", 4.7), ("Luis", 3.2)]
print("7:", reporte(datos))


