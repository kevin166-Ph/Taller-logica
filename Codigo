# 9. Agrupar productos
# ===============================
def agrupar(productos):
    categorias = {}
    for producto, categoria in productos:
        categorias.setdefault(categoria, []).append(producto)
    return categorias

productos = [("manzana", "fruta"), ("zanahoria", "verdura")]
print("9:", agrupar(productos))


# ===============================
# 10. Votaciones
# ===============================
def contar_votos(votos, candidatos):
    conteo = {}
    invalidos = 0

    for voto in votos:
        if voto in candidatos:
            conteo[voto] = conteo.get(voto, 0) + 1
        else:
            invalidos += 1

    ganador = max(conteo, key=conteo.get)
    total_validos = sum(conteo.values())
    porcentaje = (conteo[ganador] / total_validos) * 100

    return ganador, porcentaje, invalidos

votos = ["A", "B", "A", "C", "X"]
print("10:", contar_votos(votos, ["A", "B", "C"]))
