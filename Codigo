# 5. Contar palabras
# ===============================
def contar_palabras(lista):
    frecuencia = {}
    for palabra in lista:
        frecuencia[palabra] = frecuencia.get(palabra, 0) + 1
    return frecuencia

palabras = ["hola", "adios", "hola"]
print("5:", contar_palabras(palabras))


