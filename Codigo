# 4. Inventario
# ===============================
def valor_inventario(inventario):
    total = 0
    for producto in inventario.values():
        total += producto["precio"] * producto["cantidad"]
    return total

inventario = {
    "lapiz": {"precio": 1000, "cantidad": 10},
    "cuaderno": {"precio": 5000, "cantidad": 5}
}
print("4:", valor_inventario(inventario))


