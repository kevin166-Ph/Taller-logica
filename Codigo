# 6. Temperaturas
# ===============================
def analizar_temperaturas(datos):
    todas = []
    for temps in datos.values():
        todas.extend(temps)
    return max(todas), min(todas)

temps = {
    "Bogotá": [18, 20, 17],
    "Cali": [30, 32, 31]
}
print("6:", analizar_temperaturas(temps))


