# 1. Analizar notas
# ===============================
def analizar_notas(notas):
    promedio = sum(notas) / len(notas)
    mayor = max(notas)
    menor = min(notas)
    return promedio, mayor, menor

notas = [3.5, 4.0, 2.8, 5.0]
print("1:", analizar_notas(notas))


